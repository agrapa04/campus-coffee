# Copy to deploy.env (gitignored) and fill in before deploying to Cloud Run:
#   cp deploy.env.example deploy.env && sed -i '' "s/REPLACE_ME/$(openssl rand -hex 32)/" deploy.env
# compose.prod.yaml loads this via `env_file`, so `gcloud run compose up` sets these on the service.
JWT_SECRET=REPLACE_ME
# event-sourcing (default) or relational
CAMPUS_COFFEE_PERSISTENCE_MODE=event-sourcing
# Off by default: seeding the demo fixtures creates accounts whose passwords are committed in this repo, so
# anyone could log in as an admin. Set to true ONLY for a throwaway demo, never for a real deployment.
LOAD_FIXTURES_ON_STARTUP=false
